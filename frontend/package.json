    "typescript": "5.6.2"
  },
  "devDependencies": {
    "@types/node": "20.19.25",
    "autoprefixer": "10.4.20",
    "eslint": "9.39.2",
    "eslint-config-next": "16.2.9",
    "postcss": "8.5.10",
    "prettier": "3.3.3",
    "tailwindcss": "3.4.10",
    "vitest": "4.1.9"
  },
  "overrides": {
    "postcss": "8.5.10"
