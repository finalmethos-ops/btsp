# BTSP Environment
ENVIRONMENT=local
APP_NAME=BTSP
APP_VERSION=0.1.0

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Backend
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=change-me-before-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=http://localhost:3000

# Database
POSTGRES_DB=btsp
POSTGRES_USER=btsp
POSTGRES_PASSWORD=btsp_local_password
DATABASE_URL=postgresql+psycopg://btsp:btsp_local_password@postgres:5432/btsp

# Redis
REDIS_URL=redis://redis:6379/0

# Nginx
NGINX_PORT=8080
